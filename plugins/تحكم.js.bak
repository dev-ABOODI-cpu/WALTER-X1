const fs = require('fs');
const path = require('path');

const controlPath = path.join(__dirname, '../control.json');

// 📦 قراءة الإعدادات
function getControl() {
  if (!fs.existsSync(controlPath)) {
    const defaultData = {
      welcome: true,
      antilink: true,
      antispam: false,
      autoRead: true,
      autoTyping: false,
      adminOnly: false,
      logging: true,
      vipMode: false,
      vipCommands: []
    };
    fs.writeFileSync(controlPath, JSON.stringify(defaultData, null, 2));
    return defaultData;
  }

  return JSON.parse(fs.readFileSync(controlPath, 'utf-8'));
}

// 💾 حفظ الإعدادات
function saveControl(data) {
  fs.writeFileSync(controlPath, JSON.stringify(data, null, 2));
}

module.exports = {
  command: 'تحكم',
  category: 'control',
  description: 'لوحة التحكم الرئيسية',

  async execute(sock, msg) {
    const jid = msg.key.remoteJid;
    const control = getControl();

    const text =
`⚙️ ═════ CONTROL PANEL ═════

👋 Welcome: ${control.welcome}
🚫 AntiLink: ${control.antilink}
🛡 AntiSpam: ${control.antispam}
⚡ AutoRead: ${control.autoRead}
⌨️ AutoTyping: ${control.autoTyping}
🔒 VIP Mode: ${control.vipMode}
📜 VIP Commands: ${control.vipCommands.length}

👇 اختر التعديل`;

    const buttons = [
      { buttonId: 'ctl_welcome_on', buttonText: { displayText: '🟢 Welcome ON' }, type: 1 },
      { buttonId: 'ctl_welcome_off', buttonText: { displayText: '🔴 Welcome OFF' }, type: 1 },

      { buttonId: 'ctl_antilink_on', buttonText: { displayText: '🟢 AntiLink ON' }, type: 1 },
      { buttonId: 'ctl_antilink_off', buttonText: { displayText: '🔴 AntiLink OFF' }, type: 1 },

      { buttonId: 'ctl_antispam_on', buttonText: { displayText: '🟢 AntiSpam ON' }, type: 1 },
      { buttonId: 'ctl_antispam_off', buttonText: { displayText: '🔴 AntiSpam OFF' }, type: 1 },

      { buttonId: 'ctl_vip_on', buttonText: { displayText: '🔒 VIP ON' }, type: 1 },
      { buttonId: 'ctl_vip_off', buttonText: { displayText: '🔓 VIP OFF' }, type: 1 },
    ];

    return await sock.sendMessage(jid, {
      text,
      footer: "⚡ WALTER-X CONTROL PANEL",
      buttons,
      headerType: 1
    },